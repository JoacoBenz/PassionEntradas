# =============================================================================
# PassionEntradas worker — variables de entorno
# Copiá este archivo a `.env` y completá los valores. NUNCA commitees `.env`.
# =============================================================================

# --- Credenciales del portal de agentes (SECRETO) ---------------------------
# Tu propia cuenta de agente de Passion Events. No la compartas ni la multipliques.
PE_USER=
PE_PASS=

# --- Portal (Passion Events Booking System, /admin/) ------------------------
PE_BASE_URL=https://passioneventsonline.eu/admin/
# Página de login si difiere del index del /admin/ (opcional).
PE_LOGIN_URL=
# Página de listado de eventos (relativa a PE_BASE_URL).
PE_EVENT_LIST_PATH=event_list.php
# User-Agent realista y consistente.
USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/124.0.0.0 Safari/537.36

# Solo sincronizar eventos cuya "Sub Category"/Título contengan estos textos
# (lista separada por comas, case-insensitive). Vacío = TODOS.
# Ej: PE_SYNC_CATEGORIES=World Cup,Formula 1
PE_SYNC_CATEGORIES=
# Incluir eventos "On Request" (sin precio) en el catálogo como disponible=false
# (para que el front muestre "Consultar"). true|false.
PE_INCLUDE_ON_REQUEST=true
# Pausa entre fetches de detalle, en ms (cortesía con el portal B2B).
PE_DETAIL_THROTTLE_MS=1000
# Máximo de detalles "Book" por ciclo (0 = sin límite). Si se aplica el tope,
# el ciclo se marca incompleto y NO se marcan ausentes (evita falsos agotados).
PE_MAX_DETAILS_PER_CYCLE=0

# --- Pricing ----------------------------------------------------------------
# Markup fijo. 0.20 = +20%.
PRICE_MARKUP=0.20
# Conversión opcional EUR -> ARS.
CONVERT_TO_ARS=false
# Requerido si CONVERT_TO_ARS=true. Ej: 1150.50
EUR_ARS_RATE=
# Redondeo de ARS: 100 = redondea al múltiplo de 100 más cercano; 1 = entero.
ARS_ROUND_TO=100

# --- Scheduling -------------------------------------------------------------
# Intervalo entre ciclos (se espera DESPUÉS de terminar cada ciclo). 300000 = 5 min.
# Cada ciclo hace 1 request por evento "Book" (N+1), así que valores bajos son
# agresivos para un portal B2B. Subilo si ves 429s; bajalo si necesitás más fresco.
SYNC_INTERVAL_MS=300000
# Anti-borrado: si los ítems válidos caen más que esta proporción respecto del
# último sync exitoso, se ABORTA el update. 0.7 = caída >70%.
SYNC_DROP_ABORT_RATIO=0.7
# Tamaño de lote para upsert.
UPSERT_BATCH_SIZE=500
# Tras N logins fallidos seguidos, backoff largo (no spamear el login).
MAX_LOGIN_FAILURES=5
# Cooldown cuando el portal bloquea (captcha/mfa). 900000 = 15 min.
BLOCKED_COOLDOWN_MS=900000
# Tope del backoff exponencial ante fallos. 300000 = 5 min.
MAX_BACKOFF_MS=300000

# --- Supabase (SECRETO: service_role SOLO acá, jamás en el front) -----------
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
# Connection string de Postgres SOLO para aplicar migraciones (npm run db:migrate).
SUPABASE_DB_URL=

# --- Runtime ----------------------------------------------------------------
# Directorio persistente para storageState (cookies). En Docker es un volumen.
STATE_DIR=/data
# Puerto del endpoint interno /healthz.
HEALTH_PORT=8080
# Se considera "stale" si no hubo sync exitoso en este lapso. 0 = auto (intervalo*4).
STALE_AFTER_MS=0
# pino: trace|debug|info|warn|error|fatal
LOG_LEVEL=info
