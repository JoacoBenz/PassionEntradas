# --- Supabase ---
# Project URL, ej: https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_URL=

# Anon / public key (segura para el cliente, respeta RLS)
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Service role key — SOLO del lado servidor. NUNCA la expongas al cliente.
# Se usa en los Route Handlers para crear operaciones y cambiar estados.
SUPABASE_SERVICE_ROLE_KEY=

# --- App ---
# URL pública del sitio (para armar los links de las operaciones).
# En local podés dejarlo vacío: se deriva del host de la request.
# En producción (Vercel), ej: https://tickermirror.vercel.app
NEXT_PUBLIC_SITE_URL=

# --- Tienda (TicketMirror) ---
# Número de WhatsApp para reservas/consultas, con código de país. Ej: 5491122334455
NEXT_PUBLIC_WHATSAPP=

# Los precios de la tienda se muestran en USD. La cotización EUR->USD se
# edita desde el panel (Entradas -> Precios del portal), no por env.

# --- Aviso a vendedores por cada pedido/consulta ---
# Cada pedido/consulta del cliente se registra en la app y además dispara un
# aviso a los vendedores por DOS canales: WhatsApp y email. Cada canal es
# independiente y best-effort: si le faltan sus envs, ese aviso se omite y el
# registro igual se crea.

# WhatsApp Business (Meta Cloud API)
# Token de acceso de la app de WhatsApp Business (Meta).
WHATSAPP_TOKEN=
# ID del número emisor (Phone Number ID de la Cloud API).
WHATSAPP_PHONE_ID=
# Números de los vendedores a avisar, formato internacional sin +, separados
# por coma. Ej: 5491136148053,5492944806666
WHATSAPP_VENDEDORES=
# Opcional: versión de la Graph API (default v21.0).
WHATSAPP_GRAPH_VERSION=

# Email (Resend) — reusa el proveedor del envío de credenciales.
# API key de Resend.
RESEND_API_KEY=
# Remitente verificado en Resend. Ej: "Passion Entradas <avisos@tu-dominio.com>"
EMAIL_FROM=
# Emails de los vendedores a avisar, separados por coma.
EMAIL_VENDEDORES=
