# =============================================================================
# PassionEntradas worker — variables de entorno
# Copiá este archivo a `.env` y completá los valores. NUNCA commitees `.env`.
# =============================================================================

# --- Credenciales del portal de agentes (SECRETO) ---------------------------
# Tu propia cuenta de agente de Passion Events. No la compartas ni la multipliques.
PE_USER=
PE_PASS=

# --- Portal -----------------------------------------------------------------
PE_BASE_URL=https://passioneventsonline.eu/
# URL exacta del formulario de login si difiere de la base (opcional).
PE_LOGIN_URL=
# Modo de scraping:
#   playwright -> renderiza con Chromium headless (fallback robusto)
#   api        -> replica un endpoint JSON interno (XHR) reusando la cookie.
#                 Más estable; usalo si encontraste el endpoint en DevTools > Network.
PE_SCRAPE_MODE=playwright
# Si PE_SCRAPE_MODE=api, endpoint JSON interno capturado en DevTools (opcional).
PE_API_ENDPOINT=
# User-Agent realista y consistente.
USER_AGENT=Mozilla/5.0 (X11; Linux x86_64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/124.0.0.0 Safari/537.36

# --- Pricing ----------------------------------------------------------------
# Markup fijo. 0.20 = +20%.
PRICE_MARKUP=0.20
# Conversión opcional EUR -> ARS.
CONVERT_TO_ARS=false
# Requerido si CONVERT_TO_ARS=true. Ej: 1150.50
EUR_ARS_RATE=
# Redondeo de ARS: 100 = redondea al múltiplo de 100 más cercano; 1 = entero.
ARS_ROUND_TO=100

# --- Scheduling -------------------------------------------------------------
# Intervalo entre ciclos (se espera DESPUÉS de terminar cada ciclo). 45000 = 45s.
# Nota: 30s contra un portal B2B es agresivo. Considerá 60000-120000.
SYNC_INTERVAL_MS=45000
# Anti-borrado: si los ítems válidos caen más que esta proporción respecto del
# último sync exitoso, se ABORTA el update (no se publica). 0.7 = caída >70%.
SYNC_DROP_ABORT_RATIO=0.7
# Tamaño de lote para upsert.
UPSERT_BATCH_SIZE=500
# Tras N logins fallidos seguidos, backoff largo (no spamear el login).
MAX_LOGIN_FAILURES=5
# Cooldown cuando el portal bloquea (captcha/mfa). 900000 = 15 min.
BLOCKED_COOLDOWN_MS=900000
# Tope del backoff exponencial ante fallos. 300000 = 5 min.
MAX_BACKOFF_MS=300000

# --- Supabase (SECRETO: service_role SOLO acá, jamás en el front) -----------
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
# Connection string de Postgres SOLO para aplicar migraciones (npm run db:migrate).
# Settings > Database > Connection string (URI). Opcional fuera de migraciones.
SUPABASE_DB_URL=

# --- Runtime ----------------------------------------------------------------
# Directorio persistente para storageState (cookies). En Docker es un volumen.
STATE_DIR=/data
# Puerto del endpoint interno /healthz.
HEALTH_PORT=8080
# Se considera "stale" si no hubo sync exitoso en este lapso. 0 = auto (intervalo*4).
STALE_AFTER_MS=0
# pino: trace|debug|info|warn|error|fatal
LOG_LEVEL=info
